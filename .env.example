# Copy to .env.local for local Next.js dev (never commit .env.local)
# AWS credentials: use `aws configure` / AWS_PROFILE instead of static keys when possible.

# Optional: local chatbot URL override
# CHATBOT_URL=http://localhost:8080

# Optional: Virtual Data Scientist backend.
# Local dev: start with `cd /Users/scottleduc/Projects/agentic-bi-report-platform && python3 server.py`.
# DATA_SCIENCE_MCP_BASE_URL=http://127.0.0.1:8765
# Deployed demo backend:
# DATA_SCIENCE_MCP_BASE_URL=https://fdzrbtz4sewn6nrnlnbgbykbpu0jcutl.lambda-url.us-east-1.on.aws
# DATA_SCIENCE_MCP_AUTH_MODE=aws_iam
# DATA_SCIENCE_MCP_AWS_SIGNING_SERVICE=lambda
# Optional explicit bridge override for non-IAM backends.
# DATA_SCIENCE_MCP_BRIDGE_ENABLED=false

# Bedrock model overrides (chatbot AgentCore uses agents/config.py defaults)
# BEDROCK_ROUTING_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_INTERVIEW_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Virtual Data Scientist app runtime.
# DATA_SCIENTIST_AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:441383083571:runtime/vdsagentcore_VirtualDataScientistAgent-iSOiop5y80
# DATA_SCIENTIST_AGENTCORE_ENDPOINT_NAME=DEFAULT
