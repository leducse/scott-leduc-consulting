# Copy to .env.local for local Next.js dev (never commit .env.local)
# AWS credentials: use `aws configure` / AWS_PROFILE instead of static keys when possible.

# Optional: local chatbot URL override
# CHATBOT_URL=http://localhost:8080

# Bedrock model overrides (chatbot AgentCore uses agents/config.py defaults)
# BEDROCK_ROUTING_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_INTERVIEW_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
